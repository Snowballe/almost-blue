# Copier ce fichier → android/keystore.properties (non commité, voir .gitignore)
# Générer le keystore : keytool -genkey -v -keystore almost-blue-release.keystore
#   -alias almost-blue -keyalg RSA -keysize 2048 -validity 10000
# Voir : https://reactnative.dev/docs/signed-apk-android

storeFile=almost-blue-release.keystore
storePassword=MOT_DE_PASSE_STORE
keyAlias=almost-blue
keyPassword=MOT_DE_PASSE_CLE
